# Point the console's adapters at the canonical compose stack. Copy the lines you need into
# the console's .env.local (one dir up). Each `OFFGRID_ADAPTER_<CAP>` flips a capability to its
# real OSS backend; the *_URL vars tell the adapter / Tier-3 embed where the service lives.

# Data plane — Postgres + pgvector (state, audit, AND the server-scale Brain vector store)
DATABASE_URL=postgres://offgrid:offgrid@127.0.0.1:5432/offgrid_console
OFFGRID_SEAWEEDFS_URL=http://127.0.0.1:8333

# AI plane — vector store bridge
OFFGRID_ADAPTER_RETRIEVAL=pgvector        # or: qdrant | lancedb (default)
OFFGRID_QDRANT_URL=http://127.0.0.1:6333
OFFGRID_QDRANT_COLLECTION=offgrid-brain
OFFGRID_QDRANT_API_KEY=                    # only if the Qdrant instance requires an api-key

# Admin API service token — automation / CI / integration tests authenticate to the admin API
# with `Authorization: Bearer $OFFGRID_ADMIN_TOKEN` instead of an interactive SSO session. Unset
# = SSO-only (the secure default). Set a long random value to enable.
OFFGRID_ADMIN_TOKEN=

# Secrets — OpenBao
OFFGRID_ADAPTER_SECRETS=openbao
OFFGRID_OPENBAO_URL=http://127.0.0.1:8200
OFFGRID_OPENBAO_TOKEN=offgrid-dev-token

# Identity / SSO — Keycloak
OFFGRID_ADAPTER_IDENTITY=keycloak
OFFGRID_KEYCLOAK_URL=http://127.0.0.1:8080

# Policy — Open Policy Agent
OFFGRID_ADAPTER_POLICY=opa
OFFGRID_OPA_URL=http://127.0.0.1:8181

# Guardrails — Microsoft Presidio (PII)
OFFGRID_ADAPTER_GUARDRAILS=presidio
OFFGRID_PRESIDIO_URL=http://127.0.0.1:5002

# Observability — OTel Collector → VictoriaMetrics, and Langfuse for LLM traces/cost
OFFGRID_ADAPTER_OBSERVABILITY=signoz       # signoz|langfuse|otel(default)
OFFGRID_OTLP_URL=http://127.0.0.1:4318
OFFGRID_SIGNOZ_URL=http://127.0.0.1:8428
OFFGRID_LANGFUSE_URL=http://127.0.0.1:3030  # embed UI
# Direct OTLP trace ingestion into Langfuse v3 — fans the same span stream to Langfuse as a 2nd
# target (in addition to OFFGRID_OTLP_URL). The compose stack runs Langfuse v3 with a headless
# project + fixed key pair (pk-lf-offgrid-console / sk-lf-offgrid-console), so AUTH below is
# base64("public:secret") and works out of the box. Rotate the keys in the Langfuse UI for real use.
OFFGRID_LANGFUSE_OTLP_URL=http://127.0.0.1:3030/api/public/otel
OFFGRID_LANGFUSE_AUTH=cGstbGYtb2ZmZ3JpZC1jb25zb2xlOnNrLWxmLW9mZmdyaWQtY29uc29sZQ==

# Provenance signing — how exported answers are made tamper-evident
OFFGRID_ADAPTER_PROVENANCE=ed25519         # native (HMAC, default) | ed25519 (public-key) | c2pa/sigstore (future)
# ed25519 needs a stable keypair across restarts in production (else a fresh pair is generated per
# process). Provide the private key as PEM (\n-escaped); the public half is derived + served at
# GET /api/v1/admin/sign so third parties can verify without any secret.
# OFFGRID_ED25519_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Lineage & provenance — OpenLineage → Marquez
OFFGRID_ADAPTER_LINEAGE=marquez            # or: native (no-op, implicit in audit; default)
OFFGRID_MARQUEZ_URL=http://127.0.0.1:9000
OFFGRID_MARQUEZ_WEB_URL=http://127.0.0.1:3001
OFFGRID_LINEAGE_NAMESPACE=offgrid-console

# Caching — Redis (exact + semantic response cache) ; default is in-process exact-match
OFFGRID_ADAPTER_CACHING=redis
OFFGRID_REDIS_URL=redis://127.0.0.1:6379

# SIEM — OpenSearch (log search + dashboards over the audit stream) ; default is the audit store
OFFGRID_ADAPTER_SIEM=opensearch
OFFGRID_OPENSEARCH_URL=http://127.0.0.1:9200
OFFGRID_OPENSEARCH_DASHBOARDS_URL=http://127.0.0.1:5601

# Feature flags — Unleash ; default is the first-party flag store
OFFGRID_ADAPTER_FLAGS=unleash
OFFGRID_UNLEASH_URL=http://127.0.0.1:4242
OFFGRID_UNLEASH_TOKEN=                      # frontend/client API token (from the Unleash admin UI)
OFFGRID_UNLEASH_ENV=development

# Agent QA — offline evals, online scoring, drift/degradation
# Offline evals: golden (default, recall over the Brain) | promptfoo (CLI) | ragas (sidecar, planned)
OFFGRID_ADAPTER_EVALS=golden
OFFGRID_EVAL_MODEL=gemma-local              # model the judge / evaluators call through the gateway
OFFGRID_PROMPTFOO_BIN=promptfoo             # promptfoo CLI on PATH (npx -y promptfoo also works)
OFFGRID_RAGAS_URL=http://127.0.0.1:8002     # bundled Ragas sidecar (compose `qa` profile / make qa)
# Drift: native (default, PSI over eval-score history) | evidently (bundled sidecar)
OFFGRID_ADAPTER_DRIFT=native
OFFGRID_EVIDENTLY_URL=http://127.0.0.1:8001  # bundled Evidently drift sidecar (`qa` profile)
# Online scoring posts LLM-as-judge scores to Langfuse via OFFGRID_LANGFUSE_URL + _AUTH (above).

# Agent runtime — Temporal (durable workflows)
OFFGRID_TEMPORAL_URL=http://127.0.0.1:7233
OFFGRID_TEMPORAL_UI_URL=http://127.0.0.1:8081

# MDM / Fleet Control — FleetDM (osquery) ; default is the first-party device registry.
# MIT Fleet Free (Premium is paid, not required). `make mdm`, then create an API token with
# `fleetctl` (see compose comment) and set OFFGRID_FLEET_TOKEN. With this set, the Fleet module
# gains live osquery, per-device software/CVE inventory, and FleetDM policy CRUD (on g6 the URL is
# the S1 edge-Caddy loopback 127.0.0.1:8934). FLEET_URL / FLEET_TOKEN are honored as aliases.
OFFGRID_ADAPTER_MDM=fleetdm                 # or: native (in-console registry; default)
OFFGRID_FLEET_URL=http://127.0.0.1:8070
OFFGRID_FLEET_TOKEN=

# Inference / grounding — the first-party gateway (NOT in compose)
OFFGRID_GATEWAY_URL=http://127.0.0.1:7878
