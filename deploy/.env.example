# Point the console's adapters at the canonical compose stack. Copy the lines you need into
# the console's .env.local (one dir up). Each `OFFGRID_ADAPTER_<CAP>` flips a capability to its
# real OSS backend; the *_URL vars tell the adapter / Tier-3 embed where the service lives.

# Data plane — Postgres + pgvector (state, audit, AND the server-scale Brain vector store)
DATABASE_URL=postgres://offgrid:offgrid@127.0.0.1:5432/offgrid_console
OFFGRID_SEAWEEDFS_URL=http://127.0.0.1:8333

# AI plane — vector store bridge
OFFGRID_ADAPTER_RETRIEVAL=pgvector        # or: qdrant | lancedb (default)
OFFGRID_QDRANT_URL=http://127.0.0.1:6333

# Secrets — OpenBao
OFFGRID_ADAPTER_SECRETS=openbao
OFFGRID_OPENBAO_URL=http://127.0.0.1:8200
OFFGRID_OPENBAO_TOKEN=offgrid-dev-token

# Identity / SSO — Keycloak
OFFGRID_ADAPTER_IDENTITY=keycloak
OFFGRID_KEYCLOAK_URL=http://127.0.0.1:8080

# Policy — Open Policy Agent
OFFGRID_ADAPTER_POLICY=opa
OFFGRID_OPA_URL=http://127.0.0.1:8181

# Guardrails — Microsoft Presidio (PII)
OFFGRID_ADAPTER_GUARDRAILS=presidio
OFFGRID_PRESIDIO_URL=http://127.0.0.1:5002

# Observability — OTel Collector → VictoriaMetrics, and Langfuse for LLM traces/cost
OFFGRID_ADAPTER_OBSERVABILITY=signoz       # signoz|langfuse|otel(default)
OFFGRID_OTLP_URL=http://127.0.0.1:4318
OFFGRID_SIGNOZ_URL=http://127.0.0.1:8428
OFFGRID_LANGFUSE_URL=http://127.0.0.1:3030  # embed UI (always works, any version)
# Direct OTLP trace ingestion into Langfuse — fans the same span stream to Langfuse as a 2nd
# target. Requires Langfuse v3+ (the compose pin is v2 → use the embed UI/SDK instead). AUTH is
# base64("public-key:secret-key") from the Langfuse project settings.
# OFFGRID_LANGFUSE_OTLP_URL=http://127.0.0.1:3030/api/public/otel
# OFFGRID_LANGFUSE_AUTH=cGstbGY6c2stbGY=

# Lineage & provenance — OpenLineage → Marquez
OFFGRID_ADAPTER_LINEAGE=marquez            # or: native (no-op, implicit in audit; default)
OFFGRID_MARQUEZ_URL=http://127.0.0.1:9000
OFFGRID_MARQUEZ_WEB_URL=http://127.0.0.1:3001
OFFGRID_LINEAGE_NAMESPACE=offgrid-console

# Agent runtime — Temporal (durable workflows)
OFFGRID_TEMPORAL_URL=http://127.0.0.1:7233
OFFGRID_TEMPORAL_UI_URL=http://127.0.0.1:8081

# Inference / grounding — the first-party gateway (NOT in compose)
OFFGRID_GATEWAY_URL=http://127.0.0.1:7878
