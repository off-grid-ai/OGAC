# Off Grid — RAGAS sidecar compose env (COPY to .env on the server; .env is gitignored).
#
# The sidecar forwards this key to the on-prem gateway as a Bearer when it runs ragas's judge LLM +
# embeddings. The aggregator on :8800 rejects the built-in `offgrid-local` default with 401, which
# silently degrades every eval to the first-party heuristic. Set the REAL static gateway key here —
# it's the same value as OFFGRID_GATEWAY_API_KEY in the console's server-side .env.local.
#
#   cd deploy/onprem/ragas-sidecar
#   cp .env.example .env && $EDITOR .env      # paste the real oglb_… key
#   docker compose up -d --build              # compose auto-loads .env
OFFGRID_GATEWAY_API_KEY=oglb_replace_with_real_gateway_key
