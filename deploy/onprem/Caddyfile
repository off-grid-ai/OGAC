# Off Grid on-prem edge (runs on S1 = 192.168.1.84, container publishes :80).
# LAN-only, plain HTTP (names resolve only via the local dnsmasq — invisible off-network),
# so disable Caddy's automatic HTTPS/ACME (the names aren't internet-reachable).
{
	auto_https off
	admin off
}

# ── Console ──────────────────────────────────────────────────────────────────
# UI + /api → load-balanced across both Console app instances (S1, S2).
# /v1/* + /healthz → load-balanced across the gateway inference pool (G1/G2/G3).
http://onprem-console.getoffgridai.co {
	@gw path /v1/* /healthz
	handle @gw {
		reverse_proxy 192.168.1.82:7878 192.168.1.83:7878 192.168.1.86:7878 {
			lb_policy round_robin
			health_uri /healthz
			health_interval 10s
			health_timeout 3s
		}
	}
	handle {
		reverse_proxy 192.168.1.84:3000 192.168.1.85:3000 {
			lb_policy round_robin
			health_uri /
			health_interval 10s
		}
	}
}

# ── Landing page ─────────────────────────────────────────────────────────────
http://local.getoffgridai.co {
	reverse_proxy 192.168.1.84:3100
}
