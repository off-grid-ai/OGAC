{
	auto_https off
	admin off
}

# Keycloak-gated UIs (via oauth2-proxy forward_auth). arg0 = upstream.
(gated) {
	handle /oauth2/* {
		reverse_proxy 127.0.0.1:4180 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto https
		}
	}
	handle {
		forward_auth 127.0.0.1:4180 {
			uri /oauth2/auth
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto https
			copy_headers X-Auth-Request-User X-Auth-Request-Email
			@denied status 401 403
			handle_response @denied {
				redir https://{host}/oauth2/start?rd=https://{host}{uri}
			}
		}
		reverse_proxy {args[0]}
	}
}

http://console-status.getoffgridai.co {
	import gated 127.0.0.1:9100
}
http://console-landing.getoffgridai.co {
	import gated 127.0.0.1:3100
}
http://gungnir.getoffgridai.co {
	import gated 192.168.1.60:7799
}

# ungated (self-auth / API-key) — direct proxy
http://onprem-console.getoffgridai.co, http://127.0.0.1 {
	reverse_proxy 127.0.0.1:3000
}
http://gateway.getoffgridai.co {
	reverse_proxy 127.0.0.1:8800
}
