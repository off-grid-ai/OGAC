{
	auto_https off
	admin off
	# Custom modules: WAF runs first, rate-limit just before the proxy.
	order coraza_waf first
	order rate_limit before reverse_proxy
}

# Owned-login gate: forward_auth to the console session check; unauthenticated
# users are redirected to OUR /signin (not a hosted IdP page). arg0 = upstream.
(gated) {
	forward_auth 127.0.0.1:3000 {
		uri /api/auth/verify
		@denied status 401 403
		handle_response @denied {
			redir https://onprem-console.getoffgridai.co/signin?callbackUrl=https://{host}{uri}
		}
	}
	reverse_proxy {args[0]}
}

# Edge policy in ONE place: JSON access log (console reads it for blocks), a
# Coraza WAF with core protections, and a per-IP rate limit. args: 0=zone 1=events/min.
# Health check probes (/healthz) bypass the rate limiter so monitors are never throttled.
(edge) {
	log {
		output file /Users/admin/offgrid/console/deploy/edge-access.log {
			roll_size 20mb
			roll_keep 5
		}
		format json
	}
	coraza_waf {
		directives `
			SecRuleEngine On
			SecRequestBodyAccess On
			SecResponseBodyAccess Off
			SecRule REQUEST_URI "@rx (?i)(\.\./|\.\.\\|/etc/passwd|/proc/self/|/bin/sh)" "id:1001,phase:1,deny,status:403,log,msg:'Path traversal'"
			SecRule ARGS|REQUEST_URI "@rx (?i)(union(\s|/\*.*\*/)+select|\bselect\b.+\bfrom\b|insert\s+into\s|drop\s+table|'\s+or\s+'1'\s*=\s*'1)" "id:1002,phase:2,deny,status:403,log,msg:'SQL injection'"
			SecRule ARGS|REQUEST_HEADERS:User-Agent|REQUEST_URI "@rx (?i)(<script|onerror\s*=|javascript:|onload\s*=|document\.cookie)" "id:1003,phase:2,deny,status:403,log,msg:'XSS'"
			SecRule REQUEST_HEADERS:User-Agent "@rx (?i)(sqlmap|nikto|nmap|masscan|acunetix|nessus|dirbuster|fimap|whatweb|zgrab)" "id:1004,phase:1,deny,status:403,log,msg:'Scanner user-agent'"
		`
	}
	# Rate-limit all traffic EXCEPT /healthz probes — monitors must never be throttled.
	@rateable not path /healthz
	rate_limit @rateable {
		# Behind the Cloudflare tunnel every request's remote host is 127.0.0.1, so
		# key on the real client IP Cloudflare forwards. Empty (direct LAN) = one
		# shared bucket, which is fine since the LAN is trusted.
		zone {args[0]} {
			key {http.request.header.Cf-Connecting-Ip}
			events {args[1]}
			window 1m
		}
	}
}

http://console-status.getoffgridai.co {
	import gated 127.0.0.1:9100
}
http://console-landing.getoffgridai.co {
	import gated 127.0.0.1:3100
}
# Provit (Prove It — visual QA). Formerly gungnir.* — the old name 301-redirects here.
# Provit is the FREE PUBLIC showcase: the demo-walk paths (repos → features → session → live) and
# the read-only APIs they call bypass auth; everything else (/judge, /review, admin APIs) stays gated.
# Repo is the source of truth — mirrors the live edge config applied on S1. Provit runs on S1 (native
# :7799) so this is a same-host loopback hop — 127.0.0.1 by design (not a fleet IP; mDNS not needed).
http://provit.getoffgridai.co {
	@public path / /try /repos /features /session /live/* /api/try* /api/showcase* /api/mapped* /api/features* /api/session* /api/runs* /api/repos* /assets/*
	handle @public {
		reverse_proxy 127.0.0.1:7799
	}
	handle {
		import gated 127.0.0.1:7799
	}
}
http://gungnir.getoffgridai.co {
	redir https://provit.getoffgridai.co{uri} permanent
}

http://onprem-console.getoffgridai.co, http://127.0.0.1 {
	reverse_proxy 127.0.0.1:3000
}

# AI Gateway (LLM) — OpenAI-compatible aggregator on :8800, behind the edge. Auth
# (Keycloak JWT / API key) is still enforced by the aggregator. Moved here from
# gateway.* so that name is free for the general network gateway below.
http://ai.getoffgridai.co {
	import edge ai 120
	reverse_proxy 127.0.0.1:8800
}

# Network / API gateway — the general public HTTP gateway fronting the console's API
# (file storage, etc.) with the edge policy. Only /api/* is proxied; anything else
# gets a plain banner so the console UI isn't served from this host.
http://gateway.getoffgridai.co {
	import edge apigw 300
	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:3000
	}
	# Public file store (SeaweedFS S3 on localhost:8333). Reads (GET/HEAD) are public so
	# media is world-readable; writes (PUT/POST/DELETE/PATCH) are gated by forward_auth to
	# the console, which requires a valid Keycloak bearer (see /api/auth/verify-write).
	# handle_path strips the /files prefix, so /files/<bucket>/<key> → S3 /<bucket>/<key>.
	handle_path /files/* {
		@writes method PUT POST DELETE PATCH
		forward_auth @writes 127.0.0.1:3000 {
			uri /api/auth/verify-write
		}
		reverse_proxy 127.0.0.1:8333
	}
	handle {
		respond "Off Grid — network gateway" 200
	}
}

# ── Internal S2-service proxies (localhost only) ────────────────────────────────
# The console (next-server) can't egress to the LAN on this box — LAN connects fail with
# EHOSTUNREACH while localhost works (macOS 15 Local-Network privacy blocks the SSH-launched
# daemon; curl/short-lived node aren't blocked). Caddy (launchd) CAN reach the aux node, so we
# front each aux HTTP service on 127.0.0.1 and point the console's OFFGRID_*_URL at these.
# Loopback-bound → never exposed to the tunnel/LAN.
# 2026-07-05: aux tier moved S2 → g6 (S2 retired). Repointed to offgrid-g6.local.
http://127.0.0.1:8931 {
	reverse_proxy offgrid-g6.local:3030
}
http://127.0.0.1:8932 {
	reverse_proxy offgrid-g6.local:4242
}
http://127.0.0.1:8933 {
	reverse_proxy offgrid-g6.local:8088
}
http://127.0.0.1:8934 {
	reverse_proxy offgrid-g6.local:8070
}
# ── No-auth backend services: edge-exposure analysis (Phase 4.10-A) ─────────────
# Presidio, Marquez, and OPA are stock images with ZERO built-in auth. The rule is
# "not reachable unauthenticated from OUTSIDE." Two boundaries matter — and the edge
# gate belongs at only one of them:
#
#   (1) PUBLIC (internet, via the Cloudflare tunnel): ALREADY closed, no vhost added.
#       The tunnel ingress (deploy/onprem/cloudflared-tunnel.yml) routes only console,
#       gateway, auth, ssh, provit, console-status/-landing, gungnir, console-api —
#       everything else falls to `http_status:404`. NONE of these three services has a
#       tunnel hostname, and the one broad public vhost (console-api, below) proxies
#       only to the console (:3000) and the LLM aggregator (:8800), never to Marquez/
#       OPA/Presidio. So from the internet they are already unreachable. Adding an
#       `import gated` here would be wrong (see (2)) — there is nothing public to gate.
#
#   (2) These are consumed SERVER-TO-SERVER by next-server over loopback:
#         • Marquez  — src/lib/marquez.ts,          OFFGRID_MARQUEZ_URL=http://127.0.0.1:9000
#         • OPA      — src/lib/adapters/policy.ts,   OFFGRID_OPA_URL=http://127.0.0.1:8181
#         • Presidio — src/lib/adapters/pii.ts, via the 8938/8939 loopback proxies below
#       A browser-login `import gated` on any of these would 302 the console's OWN
#       machine-to-machine calls to /signin and BREAK Guardrails, Lineage, and Policy.
#       So the correct gate is NETWORK reachability, not a login redirect:
#         • Marquez & OPA run on S1; the console dials them on 127.0.0.1. Their Docker
#           host ports are bound to loopback (127.0.0.1:9000 / 127.0.0.1:8181) in the
#           compose files (docker-compose.yml + onprem/services-node-a.yml) so the LAN
#           can't reach them while the same-host console still can. No Caddy vhost needed.
#         • Presidio runs on g6 (LAN); S1's Caddy must still dial g6:5002/5001, so g6's
#           ports stay LAN-bound and are firewalled to S1 only at g6 (a stock Presidio
#           can't verify a bearer, so the network boundary is the gate — recorded in
#           SERVER_STATE.md as the required g6 host-firewall rule).
#       The 8938/8939 Caddy vhosts below are `http://127.0.0.1:...` — Caddy binds them to
#       loopback, so they are NOT reachable from the LAN or tunnel; they exist only so
#       next-server (which can't egress to the LAN on this box) can hop to g6. This is the
#       intended shape of the edge gate for a machine-to-machine path: confine reachability,
#       don't wrap a human-login redirect around it.
#
# NOTE: OpenSearch (:9200), Marquez (:9000), OpenBao (:8200) run in the `offgrid-services-a` stack
# ON S1 (localhost) — the console reaches them DIRECTLY at 127.0.0.1, no proxy needed. (The aborted
# 2026-07-05 g5/node-c plan is void: those services were already up on S1 the whole time.)
# Presidio (g6) — analyzer :5002 / anonymizer :5001 → entity-grade PII masking in Guardrails.
# These DO need a loopback proxy (g6 is on the LAN, which the console daemon can't reach directly).
# Loopback-bound (site address 127.0.0.1) → reachable only from S1, never the LAN/tunnel.
http://127.0.0.1:8938 {
	reverse_proxy offgrid-g6.local:5002
}
http://127.0.0.1:8939 {
	reverse_proxy offgrid-g6.local:5001
}

