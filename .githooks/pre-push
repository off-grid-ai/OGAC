#!/usr/bin/env bash
#
# Off Grid Console — pre-push gate.
#
# Blocks a push unless the code typechecks AND the unit-testable logic layer
# (`src/lib` pure logic + adapters' pure paths, per .c8rc.json's include/exclude)
# meets the coverage bar: branches / statements / lines / functions each ≥85%
# (conditions are covered via branch coverage). See CLAUDE.md § Engineering
# standards → "Coverage bar (≥85%, enforced)".
#
# It ALSO runs dependency-cruiser (`npm run depcruise`) to block a push on any
# ERROR-level architecture violation — most importantly an eager-value circular
# import (the Node-22-only TDZ prod-build crash class). depcruise exits non-zero
# on errors only; WARN-level findings (type-only cycles, orphans) are advisory
# and do NOT block. See .dependency-cruiser.js for the ruleset + rationale.
#
# It ALSO runs jscpd (`npm run jscpd`) — the copy/paste detector — to block a
# push if code duplication climbs past the ratcheting threshold in .jscpd.json,
# mechanically enforcing CLAUDE.md hygiene §C DRY ("duplicated logic that drifts
# is a defect"). jscpd exits non-zero only when duplication exceeds the threshold
# (baseline-then-ratchet, currently just above the real baseline). See .jscpd.json
# + docs/GAPS_BACKLOG.md (G-CPD-*) for the clone burn-down list.
#
# INSTALL (one-time, per clone — hooks are not copied by `git clone`):
#     npm run hooks:install        # == git config core.hooksPath .githooks
# This points git at the repo-tracked .githooks/ dir so every dev gets the gate.
# Undo with:  git config --unset core.hooksPath
#
# BYPASS (emergencies only — you own the consequences):
#     git push --no-verify
#
# NOTE: run from the repo root; package.json scripts resolve relative to it.

set -euo pipefail

# Resolve to the repo root so the hook works from any subdir / worktree.
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "pre-push: typecheck…"
npm run --silent typecheck

echo "pre-push: coverage:check (branches/statements/lines/functions ≥85%)…"
npm run --silent coverage:check

echo "pre-push: depcruise (no eager-value circular imports / boundary breaks)…"
npm run --silent depcruise

echo "pre-push: jscpd (code duplication ≤ threshold — DRY §C)…"
npm run --silent jscpd

echo "pre-push: OK — typecheck clean, coverage above the bar, dependency graph clean, duplication under the bar."
