    "@offgrid/finops": "file:../shared/packages/finops",
    "@offgrid/gateway": "file:../gateway",
    "@offgrid/policy": "file:../shared/packages/policy",
    "@offgrid/vectordb": "file:../shared/packages/vectordb",
    "@phosphor-icons/react": "^2.1.10",
    "@scalar/nextjs-api-reference": "^0.11.5",
    "@xyflow/react": "^12.11.1",
    "c2pa-node": "^0.5.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.40.0",
    "mssql": "^12.7.0",
    "mysql2": "^3.22.5",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sigstore": "^5.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
