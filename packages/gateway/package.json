{
  "name": "@offgrid/gateway",
  "version": "0.1.0",
  "description": "Off Grid AI's local, OpenAI-compatible gateway — run open models (text, vision, image, voice, speech) on-device, behind one API. Embeddable in Electron or run standalone.",
  "license": "LicenseRef-Off-Grid-AI-1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "offgrid-gateway": "./dist/cli.js",
    "offgrid-gateway-cluster": "./dist/cluster-cli.js",
    "offgrid-gateway-queue": "./dist/queue-cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./queue": {
      "types": "./dist/queue/index.d.ts",
      "import": "./dist/queue/index.js",
      "require": "./dist/queue/index.cjs"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0"
  },
  "peerDependencies": {
    "@xenova/transformers": "*",
    "sharp": "*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/off-grid-ai/gateway.git"
  }
}
